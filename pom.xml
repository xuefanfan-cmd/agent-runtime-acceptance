<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.0.5</version>
        <relativePath/>
    </parent>

    <groupId>com.huawei.ascend</groupId>
    <artifactId>spring-ai-ascend-sit</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <packaging>jar</packaging>

    <name>spring-ai-ascend-sit</name>
    <description>SIT (System Integration Testing) framework for spring-ai-ascend platform</description>

    <properties>
        <java.version>21</java.version>
        <a2a-sdk.version>1.0.0.Final</a2a-sdk.version>
        <awaitility.version>4.2.2</awaitility.version>
        <okhttp.version>4.12.0</okhttp.version>
        <testcontainers.version>2.0.5</testcontainers.version>
        <allure.version>2.35.3</allure.version>
        <!-- agent-runtime-java (com.openjiuwen) — white-box contract tests (e.g. Feat003) reach into
             SUT middleware classes. The aggregator `agent-runtime-java` is pom-only (no classes);
             `agent-service-app` is the jar that transitively brings spec + adapters-common +
             adapters-agentcore, covering all referenced com.openjiuwen.service.* packages. LOCAL-ONLY. -->
        <agent-runtime-java.version>0.1.0</agent-runtime-java.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>io.qameta.allure</groupId>
                <artifactId>allure-bom</artifactId>
                <version>${allure.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <!-- ================================================================ -->
        <!-- A2A Protocol SDK — replaces raw HTTP client for SUT calls       -->
        <!-- ================================================================ -->
        <dependency>
            <groupId>org.a2aproject.sdk</groupId>
            <artifactId>a2a-java-sdk-client</artifactId>
            <version>${a2a-sdk.version}</version>
        </dependency>

        <!-- YAML config parsing for TestConfig -->
        <dependency>
            <groupId>com.fasterxml.jackson.dataformat</groupId>
            <artifactId>jackson-dataformat-yaml</artifactId>
        </dependency>

        <!-- Async state polling — used in src/main/WaitUtils + src/test -->
        <dependency>
            <groupId>org.awaitility</groupId>
            <artifactId>awaitility</artifactId>
            <version>${awaitility.version}</version>
        </dependency>

        <!-- HTTP mock server — Card validation tests need mock agent returning invalid Card -->
        <dependency>
            <groupId>com.squareup.okhttp3</groupId>
            <artifactId>mockwebserver</artifactId>
            <version>${okhttp.version}</version>
            <scope>test</scope>
        </dependency>

        <!-- ================================================================ -->
        <!-- Test Framework (src/test): JUnit 5 + AssertJ + Mockito          -->
        <!-- ================================================================ -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- JUnit Platform Suite — @Suite, @SelectPackages, @IncludeTags -->
        <dependency>
            <groupId>org.junit.platform</groupId>
            <artifactId>junit-platform-suite</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Allure JUnit 5 integration — auto-registers a JUnit Platform listener
             that writes test results to target/allure-results/ on every test run.
             Populates the data that allure:report / allure generate assemble.
             NOTE: the original allure-junit5 artifact was relocated to allure-jupiter. -->
        <dependency>
            <groupId>io.qameta.allure</groupId>
            <artifactId>allure-jupiter</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Testcontainers core — compile scope: the src/main fault-injection mechanism (FaultLink/ToxiproxyFaultLink) depends on it -->
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers</artifactId>
            <version>${testcontainers.version}</version>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-junit-jupiter</artifactId>
            <version>${testcontainers.version}</version>
            <scope>test</scope>
        </dependency>

        <!-- Toxiproxy — TCP fault injection (reset_peer / latency / timeout); compile scope: backs the src/main FaultLink mechanism (chaos tests, C-10) -->
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-toxiproxy</artifactId>
            <version>${testcontainers.version}</version>
        </dependency>

        <!-- agent-runtime-java SUT classes — white-box contract tests (Feat003 Redis middleware
             configuration/diagnostics) reach into com.openjiuwen.service.* middleware internals.
             LOCAL-ONLY dependency (not for commit): resolves the 5 missing-package compile errors.
             See <agent-runtime-java.version> note above on why agent-service-app, not the aggregator.
             agent-service-adapters-agentcore is declared explicitly: it reaches the tree only via the
             pom-packaging agent-service hop, which Maven drops without <type>pom</type>. -->
        <dependency>
            <groupId>com.openjiuwen</groupId>
            <artifactId>agent-service-app</artifactId>
            <version>${agent-runtime-java.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>com.openjiuwen</groupId>
            <artifactId>agent-service-adapters-agentcore</artifactId>
            <version>${agent-runtime-java.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Surefire — JUnit 5 engine -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <!-- Default: run only component + integration (skip e2e / performance) -->
                    <excludedGroups>e2e,performance</excludedGroups>
                </configuration>
            </plugin>

            <!-- Failsafe — for e2e and performance suites (IT.*) -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
                <configuration>
                    <groups>e2e</groups>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>integration-test</goal>
                            <goal>verify</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <!-- Compiler — Java 21 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <compilerArgs>
                        <arg>--enable-preview</arg>
                    </compilerArgs>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <!-- Profile-activated: `./mvnw allure:report -Pallure-report` (or `allure:serve`).
         Kept inside a profile so the plugin's auto-download of Node.js + the Allure 3
         binary is NEVER triggered during normal builds (mvn test / verify / install).
         run-pipeline.sh Stage 4 uses `allure generate` from the locally-installed CLI
         instead — see the nvm-loading guard there. -->
    <profiles>
        <profile>
            <id>allure-report</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>io.qameta.allure</groupId>
                        <artifactId>allure-maven</artifactId>
                        <version>3.0.2</version>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
